# Vercel / production — set these in the Vercel project dashboard (Settings → Environment Variables)

# PostgreSQL (Railway, Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session signing (use a long random string in production)
JWT_SECRET=change-me-in-production

# Optional: separate secret for derived user passwords (defaults to JWT_SECRET)
# USER_PASSWORD_SECRET=

# Required for Vercel builds (can stay as-is)
NODE_ENV=production
PORT=5173
BASE_PATH=/
